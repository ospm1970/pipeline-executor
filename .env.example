# Manus DevAgents MVP - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores

# ===== OPENAI API =====
# Obtenha sua chave em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sua_chave_openai_aqui

# ===== AUTENTICAÇÃO =====
# Chave de API para autenticar requisições (envie no header x-api-key)
API_KEY=

# ===== GITHUB =====
# Token para operações de push automático (opcional se enviado no body da requisição)
GITHUB_TOKEN=

# ===== SERVIDOR =====
# Porta em que a aplicação será executada (padrão: 3001)
PORT=3001

# ===== BANCO DE DADOS =====
# Tipo de banco de dados (sqlite, mysql, postgresql)
DB_TYPE=sqlite

# Para SQLite (padrão - sem configuração adicional necessária)
# O arquivo será criado automaticamente em ./data/manus.db

# Para MySQL/PostgreSQL (opcional)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=seu_usuario
# DB_PASSWORD=sua_senha
# DB_NAME=manus_devagents

# ===== DOCUMENTAÇÃO =====
# Diretório para armazenar documentação gerada
DOCS_DIR=./docs

# ===== AMBIENTE =====
# Ambiente de execução (development, production)
NODE_ENV=development

# ===== LOGS =====
# Nível de log (error, warn, info, debug)
LOG_LEVEL=info

# ===== SEGURANÇA =====
# Origens permitidas para CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3001

# Modelo OpenAI a ser usado pelos agentes (ex: gpt-4.1-mini, gpt-4o)
OPENAI_MODEL=gpt-4.1-mini

# ===== GITHUB PR =====
# Branch base para Pull Requests criados pelo pipeline
DEFAULT_BASE_BRANCH=main
