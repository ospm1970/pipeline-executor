{
  "name": "pipeline-executor",
  "version": "1.0.0",
  "description": "Pipeline de desenvolvimento automatizado orientado por IA — Casarcom",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "prod": "node server.js",
    "build": "echo 'No build needed'",
    "test": "node --test tests/integration.test.js",
    "test:plan-validation": "node scripts/run-validation-plan.mjs",
    "test:ui": "playwright test --config=tests/playwright.config.js",
    "monitor:pipeline": "node scripts/run-pipeline-monitor.mjs",
    "pipeline:resume": "node scripts/run-pipeline-resume.mjs",
    "pipeline:checkpoint:inspect": "node scripts/run-pipeline-resume.mjs --inspect"
  },
  "keywords": [
    "ai",
    "agents",
    "development",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "openai": "^4.52.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
